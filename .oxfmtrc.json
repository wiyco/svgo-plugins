{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/pnpm-lock.yaml",
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**"
  ],
  "endOfLine": "lf",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 80,
  "objectWrap": "preserve",
  "sortImports": true
}
