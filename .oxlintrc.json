{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "import", "typescript", "node", "vitest"],
  "env": {
    "builtin": true,
    "node": true
  },
  "ignorePatterns": [
    "**/pnpm-lock.yaml",
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**"
  ],
  "options": {
    "denyWarnings": true
  },
  "rules": {
    "eqeqeq": "error",
    "import/no-cycle": "error",
    "typescript/consistent-type-imports": "error"
  },
  "overrides": [
    {
      "files": [
        "apps/playground/**/src/**/*.ts",
        "apps/playground/**/src/**/*.tsx"
      ],
      "env": {
        "browser": true
      },
      "plugins": [
        "eslint",
        "import",
        "typescript",
        "node",
        "vitest",
        "react",
        "react-perf",
        "jsx-a11y"
      ]
    },
    {
      "files": ["**/__tests__/**/*.ts", "**/*.test.ts", "**/*.test.tsx"],
      "env": {
        "vitest": true
      }
    }
  ]
}
